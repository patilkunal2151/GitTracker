<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Scaled up and centered group for better visibility in notifications -->
    <group
        android:pivotX="12"
        android:pivotY="12"
        android:scaleX="1.6"
        android:scaleY="1.6"
        android:translateX="-0.5">

        <!-- Main Stem - Thicker stroke for visibility -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M9,16 L9,8"
            android:strokeWidth="1.5"
            android:strokeColor="#FFFFFF"
            android:strokeLineCap="round" />

        <!-- Branch -->
        <path
            android:pathData="M9,12 C9,10 10,9 14,9"
            android:strokeWidth="1.5"
            android:strokeColor="#FFFFFF"
            android:strokeLineCap="round"
            android:strokeLineJoin="round" />

        <!-- Nodes -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M9,17m-1.3,0a1.3,1.3 0 1,1 2.6,0a1.3,1.3 0 1,1 -2.6,0" />
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M9,7m-1.3,0a1.3,1.3 0 1,1 2.6,0a1.3,1.3 0 1,1 -2.6,0" />
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M15,9m-1.3,0a1.3,1.3 0 1,1 2.6,0a1.3,1.3 0 1,1 -2.6,0" />

        <!-- Pulse effect - Thickened to avoid disappearing -->
        <path
            android:pathData="M15,9m-2.8,0a2.8,2.8 0 1,1 5.6,0a2.8,2.8 0 1,1 -5.6,0"
            android:strokeWidth="0.6"
            android:strokeAlpha="0.7"
            android:strokeColor="#FFFFFF" />
    </group>
</vector>
